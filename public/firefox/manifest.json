{
  "manifest_version": 3,
  "name": "Easy Speed Dial",
  "version": "2.13.2",
  "permissions": ["bookmarks", "storage", "unlimitedStorage"],
  "host_permissions": ["https://www.bing.com/*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "easy-speed-dial@ctuzzeo",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "description": "Easy Speed Dial replaces the new tab page with a colorful grid of your bookmarks and folders.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_title": "Easy Speed Dial",
    "default_icon": "icons/32.svg"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/16.svg",
    "32": "icons/32.svg",
    "48": "icons/48.svg",
    "64": "icons/64.svg",
    "96": "icons/96.svg",
    "128": "icons/128.svg",
    "256": "icons/256.svg",
    "512": "icons/512.svg",
    "1024": "icons/1024.svg"
  },
  "author": "Lucas Everett",
  "homepage_url": "https://easyspeeddial.com"
}
